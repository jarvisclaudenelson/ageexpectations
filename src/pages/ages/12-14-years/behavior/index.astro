const title = '12–14 Year Old Behavior: Understanding Early Adolescent Emotions and Actions';
const description = 'Understanding early teen behavior — risk-taking, pushing back, emotional intensity, social anxiety, sleep fights, and how to maintain connection while setting effective limits, with AAP guidance.';

const faqs = [
  {
    question: 'Why does my 13-year-old make decisions they clearly knew were wrong?',
    answer: 'The adolescent brain processes rewards and risks through the limbic system (emotional, reactive) faster than through the prefrontal cortex (logical, planning). In peer-present or emotionally activated situations, the reward-seeking system typically wins — regardless of what teens "know" when calm. This is why teens can explain exactly why something is risky and then do it anyway. The AAP notes this limbic-cortical imbalance is biological and resolves gradually through the mid-20s (AAP, 2022). Structure and reduced exposure to high-risk situations helps more than lectures.'
  },
  {
    question: 'My 14-year-old slams doors and says things like "I hate this family." Is this normal?',
    answer: 'Behavioral dysregulation of this kind — door-slamming, verbal intensity, dramatic statements — is common in early adolescence (ages 12 to 15) and reflects the combination of hormonal mood reactivity and still-developing emotional regulation. The AAP distinguishes this from abusive behavior: intensity and drama are normal; sustained verbal abuse directed at family members, physical aggression, or destruction of property are not. Address the behavior calmly after the storm, not during it.'
  },
  {
    question: 'How do I handle my 13-year-old\'s extreme social anxiety?',
    answer: 'Social anxiety is among the most common anxiety disorders in early adolescence, affecting up to 9% of adolescents (NIMH, 2022). Mild self-consciousness is normal at this age; social anxiety is diagnosable when fear of social evaluation prevents participation in normal activities — eating in the school cafeteria, speaking in class, attending social events. If your teen avoids social situations to a degree that significantly impairs their daily life, talk to your pediatrician. Cognitive behavioral therapy (CBT) is the evidence-based first-line treatment and is highly effective for adolescent social anxiety.'
  },
  {
    question: 'My 12-year-old has been caught lying repeatedly. What should I do?',
    answer: 'Deception increases in early adolescence as teens develop the cognitive ability to maintain complex false narratives and the motivation to protect an expanding private life. The AAP recommends responding with calm, direct consequences (not shock or escalating punishment), examining whether your teens feel they cannot tell you the truth without disproportionate consequences, and rebuilding trust incrementally with increasing autonomy as honesty is demonstrated (AAP, 2022). Persistent, elaborate deception that disrupts daily life warrants professional assessment.'
  },
  {
    question: 'Is it normal for my 13-year-old to be intensely moody about school?',
    answer: 'School-related distress is common in early adolescence. Middle school introduces higher academic demands, complex peer hierarchies, multiple teachers with different expectations, and puberty-related self-consciousness — simultaneously. Periodic frustration, stress, and school-related complaints are expected. Persistent avoidance of school, physical symptoms (headaches, stomachaches) that resolve on weekends, or a significant drop in grades are signs that warrant a deeper look with your pediatrician and the school.'
  },
];

const articleData = articleSchema({
  title,
  description,
  url: 'https://ageexpectations.com/ages/12-14-years/behavior/',
});
const faqData = faqSchema(faqs);
