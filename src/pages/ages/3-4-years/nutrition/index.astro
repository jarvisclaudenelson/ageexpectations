import { articleSchema, faqSchema, medicalWebPageSchema } from "../../../../data/schema.js";

const title = "What Should a 3 to 4 Year Old Be Eating? Nutrition Guide for Preschoolers";
const description = "A practical, evidence-based nutrition guide for children ages 3 to 4 covering calorie needs, portion sizes, protein, calcium, iron, picky eating, snacks, and when to talk to your pediatrician, based on USDA and AAP guidance.";

const faqs = [
  {
    question: "Is it typical that my 3-year-old only wants to eat a few foods?",
    answer: "Yes — selective eating is very common in 3–4 year olds, and many typically developing preschoolers strongly prefer familiar foods while rejecting new ones (AAP, 2022). The main goal is offering balanced meals and repeated low-pressure exposure, not forcing bites. Talk to your pediatrician if your child is losing weight, gagging often, or avoiding entire food groups."
  },
  {
    question: "How much should my 3 or 4 year old eat at each meal?",
    answer: "Most 3–4 year olds do best with 3 meals and 1–3 snacks per day, with child-sized portions that are much smaller than adult portions (USDA, 2020–2025; AAP, 2022). Appetite often varies from meal to meal. Talk to your pediatrician if your child has consistently poor intake, weight loss, or extreme restriction."
  },
  {
    question: "Should I worry if my preschooler skips dinner but seems fine otherwise?",
    answer: "Usually not — many 3–4 year olds eat unevenly across the day and may eat more at breakfast or lunch than at dinner (AAP, 2022). What matters most is the overall pattern across several days, not one light meal. Talk to your pediatrician if skipped meals happen with fatigue, constipation, poor growth, or frequent vomiting."
  },
  {
    question: "Does my 3 to 4 year old still need whole milk?",
    answer: "Most children ages 2 and older can usually transition from whole milk to low-fat or fat-free dairy unless a pediatrician recommends otherwise for growth or medical reasons (AAP, 2019). Preschoolers still need calcium and vitamin D, but they do not need unlimited milk. Talk to your pediatrician if your child drinks large amounts of milk and eats very little solid food."
  },
  {
    question: "Is juice okay for a 3 or 4 year old?",
    answer: "Yes, but only in small amounts — the AAP recommends limiting 100% fruit juice to no more than 4 ounces per day for children ages 1–3 and 4–6 ounces per day for children ages 4–6 (AAP, 2017). Whole fruit is preferred. Talk to your pediatrician if juice is replacing meals or contributing to diarrhea, dental issues, or poor appetite."
  },
  {
    question: "Should I give my preschooler a vitamin every day?",
    answer: "Not always — many 3–4 year olds who eat a varied diet do not need a daily vitamin, but vitamin D, iron, or other supplements may be appropriate in some children depending on diet and risk factors (AAP, 2022). Supplements should not replace meals. Talk to your pediatrician before starting routine vitamins, especially iron."
  },
  {
    question: "Is it typical that my 4-year-old seems hungry all the time?",
    answer: "Sometimes — appetite can increase during growth periods, on active days, or when meals lack enough protein, fiber, or healthy fats (USDA, 2020–2025). Offering structured meals and balanced snacks usually helps. Talk to your pediatrician if constant hunger comes with weight loss, excessive thirst, fatigue, or major behavior changes."
