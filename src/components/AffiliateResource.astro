---
// AffiliateResource.astro — Recommended products block for monetizable pages
// Products pulled from /src/data/affiliates.js by page key

const { pageKey } = Astro.props;

let affiliateData = null;
try {
  const { AFFILIATES } = await import('../data/affiliates.js');
  affiliateData = AFFILIATES[pageKey] || null;
} catch {}
---

{affiliateData && (
  <section class="affiliate-block">
    <h2>{affiliateData.heading}</h2>
    <p class="affiliate-disclosure">
      <em>This page contains affiliate links. If you purchase through our links, we may earn a small commission at no extra cost to you. We only recommend products we believe in.</em>
    </p>
    <ul class="affiliate-list">
      {affiliateData.products.map(product => (
        <li class="affiliate-item">
          <a href={product.url} target="_blank" rel="noopener noreferrer nofollow" class="affiliate-link">
            {product.name}
          </a>
          <p class="affiliate-desc">{product.description}</p>
        </li>
      ))}
    </ul>
  </section>
)}

<style>
  .affiliate-block {
    margin: 2.5rem 0;
    padding: 1.5rem;
    background: #f8f9fa;
    border-left: 4px solid #4a90a4;
    border-radius: 4px;
  }
  .affiliate-block h2 {
    margin-top: 0;
    font-size: 1.25rem;
    color: #2c3e50;
  }
  .affiliate-disclosure {
    font-size: 0.8rem;
    color: #666;
    margin-bottom: 1rem;
  }
  .affiliate-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .affiliate-item {
    padding: 0.75rem;
    background: white;
    border-radius: 4px;
    border: 1px solid #e0e0e0;
  }
  .affiliate-link {
    font-weight: 600;
    color: #c0392b;
    text-decoration: none;
  }
  .affiliate-link:hover {
    text-decoration: underline;
  }
  .affiliate-desc {
    margin: 0.25rem 0 0;
    font-size: 0.9rem;
    color: #555;
  }
</style>
