const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How much sleep does an 18-month-old need?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Toddlers aged 12-18 months need 11-14 hours of sleep per 24 hours, typically including 1-2 naps during the day."
