---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import { articleSchema, faqSchema, medicalWebPageSchema } from '../../../../data/schema.js';

const title = '14–18 Year Old Behavior: Teen Emotions, Independence, and Risk';
const description = 'Understanding teen behavior ages 14 to 18 — healthy risk-taking vs. dangerous risk, depression signs, relationship conflicts, independence battles, and when to involve professional help.';

const faqs = [
  {
    question: 'Is my 16-year-old\'s moodiness still normal, or is it depression?',
    answer: 'Typical moodiness in older teens is situational and episodic — triggered by specific events, with periods of normal functioning between episodes. Depression is characterized by persistent low mood or irritability lasting 2 or more weeks, loss of interest in everything previously enjoyed, significant changes in sleep and appetite, and impairment in school and social functioning (DSM-5). The AAP recommends depression screening at every well-child visit starting at age 12. If you are unsure, a pediatrician visit is always appropriate — you are not "overreacting."'
  },
  {
    question: 'My 17-year-old wants to make all their own decisions. How do I handle this?',
    answer: 'Late adolescence is the appropriate time to increase decision-making autonomy progressively. The AAP recommends moving from directive parenting (you decide what the teen does) to consultative parenting (you advise, they decide within safety parameters) during ages 15 to 18 (AAP, 2022). Pick limits carefully: safety (driving, substances, curfew) remains non-negotiable. Preferences (clothing, hair, friend choices, hobbies) should progressively belong to the teen. Every non-safety limit you hold is capital spent — spend it on what matters.'
  },
  {
    question: 'Is it normal for my 15-year-old to experiment with identity — different styles, friend groups, or beliefs?',
    answer: 'Yes. Identity experimentation is the primary developmental work of adolescence. Teens who try on different clothing styles, social groups, belief systems, and future directions are doing exactly what healthy adolescent development requires. The AAP notes that identity exploration — including religious questioning, political development, and changing friend groups — is how teens develop a stable, internalized adult identity (AAP, 2022). The concern is not experimentation; it is the absence of any exploration, or experimentation that is dangerous rather than merely different.'
  },
  {
    question: 'My 16-year-old and I argue constantly. Is our relationship normal?',
    answer: 'Conflict between parents and teens is most intense during mid-adolescence (ages 13 to 16) and typically decreases through ages 17 to 18 as identity consolidates (AAP, 2022). The content of arguments matters more than their frequency: arguments about autonomy, preferences, and rules are normal. Arguments that include contempt, abuse, or complete breakdown of basic respect warrant professional support. Maintaining warmth alongside conflict — "I love you even when we disagree" — is the most important variable for long-term relationship quality.'
  },
  {
    question: 'How do I talk to my 17-year-old about healthy relationships and consent?',
    answer: 'Conversations about healthy relationships and consent are most effective when they begin before teens are in relationships — ideally in early adolescence. By ages 16 to 17, teens benefit from specific, concrete frameworks: healthy relationships involve mutual respect, open communication, and the ability to say no without fear of the partner\'s reaction. Consent is ongoing, enthusiastic, and freely given — not assumed, pressured, or negotiated. The AAP recommends parents initiate these conversations directly rather than delegating them entirely to schools (AAP, 2022).'
  },
];

const articleData = articleSchema({
  title,
  description,
  url: 'https://ageexpectations.com/ages/14-18-years/behavior/',
});
const faqData = faqSchema(faqs);
const medicalData = medicalWebPageSchema({
  name: title,
  description,
  url: 'https://ageexpectations.com/ages/14-18-years/behavior/',
});
