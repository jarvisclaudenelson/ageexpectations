---
const { title, description, schema, pageType = 'Article' } = Astro.props;

const jsonLd = schema || {
  "@context": "https://schema.org",
  "@type": pageType,
  "headline": title,
  "description": description
};
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title} | AgeExpectations</title>
  <meta name="description" content={description}>
  <meta name="robots" content="index, follow">
  <link rel="canonical" href={`https://ageexpectations.com${Astro.url.pathname}`}>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <link rel="stylesheet" href="/styles/global.css">
</head>
<body>
  <header class="site-header">
    <div class="container">
      <a href="/" class="logo">AgeExpectations</a>
      <nav class="main-nav">
        <a href="/ages/0-1-month/">Newborn</a>
        <a href="/ages/1-3-months/">1-3 mo</a>
        <a href="/ages/3-6-months/">3-6 mo</a>
        <a href="/ages/6-9-months/">6-9 mo</a>
        <a href="/ages/9-12-months/">9-12 mo</a>
        <a href="/ages/12-18-months/">12-18 mo</a>
        <a href="/ages/18-24-months/">18-24 mo</a>
        <a href="/ages/2-3-years/">2-3 yr</a>
        <a href="/ages/3-4-years/">3-4 yr</a>
        <a href="/ages/4-5-years/">4-5 yr</a>
        <a href="/ages/5-6-years/">5-6 yr</a>
        <a href="/ages/6-8-years/">6-8 yr</a>
        <a href="/ages/8-10-years/">8-10 yr</a>
        <a href="/ages/10-12-years/">10-12 yr</a>
        <a href="/ages/12-14-years/">12-14 yr</a>
        <a href="/ages/14-18-years/">14-18 yr</a>
      </nav>
    </div>
  </header>

  <main class="main-content">
    <slot />
  </main>

  <footer class="site-footer">
    <div class="container">
      <p>AgeExpectations — Practical parenting guidance backed by evidence.</p>
      <p>Always consult your pediatrician for personalized advice.</p>
    </div>
  </footer>
</body>
</html>
