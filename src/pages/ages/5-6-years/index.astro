import BaseLayout from '@layouts/BaseLayout.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "5-6 Year Development: Kindergarten Readiness & Milestones",
  "description": "Your 5-6 year old is starting kindergarten. Learn about developmental milestones, school readiness, social skills, and what to expect at this age.",
  "author": {
    "@type": "Organization",
    "name": "AgeExpectations"
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What should a 5-year-old know before kindergarten?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Kindergarten readiness includes basic self-care (using bathroom, dressing), following directions, recognizing some letters and numbers, and social skills like sharing and taking turns. Academic skills vary widely and aren't required."
      }
    },
    {
      "@type": "Question",
      "name": "How much sleep does a 5-6 year old need?",
      "acceptedAnswer": {
        "@type": "Answer",
