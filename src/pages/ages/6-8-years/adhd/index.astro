---
import BaseLayout from "../../../../layouts/BaseLayout.astro";
import { articleSchema, faqSchema, medicalWebPageSchema } from "../../../../data/schema.js";

const title = "What Are the Signs of ADHD in a 6 to 8 Year Old?";
const description = "A practical, evidence-based guide to signs of ADHD in children ages 6 to 8. Covers what ADHD can look like at school and at home, what is typically developing versus a red flag, how ADHD is evaluated, and when to talk to your pediatrician, based on AAP and CDC guidance.";

const faqs = [
  {
    question: "Is it typical that my 6-year-old cannot sit still in class?",
    answer: "Some movement and restlessness are typical in 6-year-olds, but difficulty staying seated, listening, or completing simple tasks across both school and home settings may warrant ADHD evaluation if the pattern is persistent and impairing (AAP, 2019; CDC, 2024). Talk with your pediatrician if teachers and caregivers are seeing the same concerns consistently."
  },
  {
    question: "Should I worry if my 7-year-old is always forgetting things?",
    answer: "Frequent forgetfulness can be typical occasionally, but regularly losing homework, forgetting multi-step directions, and seeming unable to hold basic routines in mind may be a red flag for inattention in a 6–8-year-old (AAP, 2019). Talk with your pediatrician if the pattern affects school, home, or friendships."
  },
  {
    question: "Can a child have ADHD if they do well in school?",
    answer: "Yes, a child can have ADHD and still earn good grades, especially if they are bright, highly supported, or working very hard to compensate. ADHD is diagnosed based on symptoms and impairment, not grades alone (AAP, 2019). Talk with your pediatrician if effort, stress, or behavior suggest underlying attention difficulties."
  },
  {
    question: "Is my 8-year-old too young to be evaluated for ADHD?",
    answer: "No, age 8 is not too young for an ADHD evaluation. The AAP recommends evaluating children ages 4–18 who have academic or behavioral concerns and symptoms of inattention, hyperactivity, or impulsivity (AAP, 2019). Talk with your pediatrician if concerns are affecting daily functioning."
  },
  {
    question: "What is the difference between ADHD and typical high energy?",
    answer: "Typical high energy comes and goes and usually improves with structure, while ADHD symptoms are persistent, developmentally out of proportion, present in more than one setting, and interfere with learning, relationships, or daily routines (AAP, 2019; CDC, 2024). Talk with your pediatrician if the behavior is ongoing and disruptive."
  },
  {
    question: "Will my child grow out of ADHD behaviors?",
    answer: "Some children become less physically hyperactive with age, but ADHD symptoms often continue into later childhood, adolescence, and adulthood if present. Early identification helps children function better at school and at home (AAP, 2019). Talk with your pediatrician rather than using a wait-and-see approach when concerns are persistent."
  }
];

const articleData = articleSchema({
  title,
  description,
  url: "https://ageexpectations.com/ages/6-8-years/adhd/",
  datePublished: "2026-04-07",
  dateModified: "2026-04-07"
});

const faqData = faqSchema(faqs);

const medicalData = medicalWebPageSchema({
  name: title,
