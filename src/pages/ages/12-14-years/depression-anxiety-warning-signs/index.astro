---
import BaseLayout from "../../../../layouts/BaseLayout.astro";
import { articleSchema, faqSchema, medicalWebPageSchema } from "../../../../data/schema.js";

const title = "What Are the Warning Signs of Depression or Anxiety in a 12 to 14 Year Old?";
const description = "A practical, evidence-based guide to warning signs of depression and anxiety in children ages 12 to 14. Covers irritability, withdrawal, school avoidance, physical complaints, suicidal statements, what is typically developing in early adolescence, and when to talk to your pediatrician.";
const faqs = [
  {
    question: "Is it typical that my 12-year-old is suddenly irritable all the time?",
    answer: "Frequent irritability can be part of early adolescence, but irritability that lasts most of the day for 2 weeks or more, disrupts school or friendships, or comes with withdrawal, sleep changes, or loss of interest can be a depression red flag in 12–14 year olds (AAP, 2022). Talk with your pediatrician if the pattern is persistent or worsening.",
  },
  {
    question: "Should I worry if my 13-year-old keeps saying they are sick before school?",
    answer: "Repeated stomachaches, headaches, or nausea before school can be a common sign of anxiety in 12–14 year olds, especially when symptoms improve at home or on weekends (AAP, 2020; NIMH, 2023). If school avoidance is developing or physical complaints are frequent, talk with your pediatrician promptly.",
  },
  {
    question: "Is it typical that my early teen wants to spend more time alone?",
    answer: "Wanting more privacy is typically developing in 12–14 year olds, but persistent isolation from family and friends, quitting previously enjoyed activities, or refusing social contact can be a mental health red flag rather than ordinary independence (AAP, 2022). Contact your pediatrician if withdrawal lasts more than 2 weeks or is getting worse.",
  },
  {
    question: "What if my 14-year-old says 'I was just joking' after saying they want to die?",
    answer: "Any statement about wanting to die, disappear, or hurt oneself should be taken seriously, even if a 12–14 year old later says it was a joke (AAP, 2022). Contact your pediatrician the same day, and use 988 immediately if there is current suicidal thinking, a plan, or concern for immediate safety.",
  },
  {
    question: "How do I know if this is puberty moodiness or something more?",
    answer: "Puberty can bring bigger emotions, but mood changes that are intense, last at least 2 weeks, interfere with school or relationships, or come with sleep changes, hopelessness, panic, or loss of interest suggest more than typical puberty adjustment (AAP, 2022; USPSTF, 2016). A pediatrician can help sort out what needs further evaluation.",
  },
  {
    question: "Should I let my 12 to 14 year old stay home from school for anxiety?",
    answer: "Occasional short-term support may be needed, but repeated avoidance usually strengthens anxiety over time in 12–14 year olds rather than helping it resolve (AAP, 2020). If your child is regularly missing school because of fear, panic, or physical complaints, talk with your pediatrician as soon as possible.",
  },
  {
    question: "Does my child need depression screening at this age?",
    answer: "Yes. The USPSTF recommends screening adolescents ages 12 and older for major depressive disorder when systems are in place for diagnosis and follow-up care (USPSTF, 2016). If your 12–14 year old has not been screened recently, ask your pediatrician about it at the next visit.",
  }
];

const articleData = articleSchema({
  title,
  description,
  url: "https://ageexpectations.com/ages/12-14-years/depression-anxiety-warning-signs/",
  datePublished: "2026-04-03",
  dateModified: "2026-04-03"
});

const faqData = faqSchema(faqs);

const medicalData = medicalWebPageSchema({
  name: title,
