const schema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "2-3 Year Language Development: Speech Milestones",
  "description": "Language explosion at 2-3 years. Learn about vocabulary growth, sentence development, speech clarity, and when to seek help for speech delays.",
  "author": {
    "@type": "Organization",
    "name": "AgeExpectations"
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How many words should a 2-year-old say?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Most 2-year-olds have a vocabulary of 50+ words and are starting to combine two words together. By age 3, vocabularies typically reach 200+ words."
      }
    },
    {
      "@type": "Question",
      "name": "When should I worry about speech delay?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Talk to your pediatrician if your child has fewer than 50 words at 2 years, no two-word phrases by 2, or if you can't understand at least 50% of their speech by age 2."
      }
    },
    {
      "@type": "Question",
      "name": "Is it normal for my 3-year-old to stutter?",
      "acceptedAnswer": {
        "@type": "Answer",
