  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is the 4-month sleep regression?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Around 4 months, a baby's sleep architecture permanently shifts from newborn-style sleep to adult-style cycles (lighter, more easily disrupted). This is neurological maturation, not a regression — it doesn't reverse. Babies who relied on feeding or rocking to fall asleep now wake between cycles and need the same input to return to sleep."
      }
    },
    {
      "@type": "Question",
      "name": "How much solid food should a 5-month-old eat?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Most babies aren't ready for solids until 6 months (AAP recommendation). Readiness signs include sitting with minimal support, good head control, showing interest in food, and the disappearance of the tongue-thrust reflex. Starting before 4 months is not recommended."
      }
    },
    {
      "@type": "Question",
      "name": "When do babies roll over?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Front-to-back rolling typically appears first, between 3 and 5 months. Back-to-front rolling, which requires more core strength, usually follows at 4–6 months. Babies with limited tummy time often roll later."
      }
    },
    {
      "@type": "Question",
      "name": "How much should a 4-month-old eat?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Formula-fed babies typically take 4–6 oz per feeding, 5–6 times per day (total: ~24–36 oz/day). Breastfed babies nurse 5–7 times per day. Demand still leads the schedule at this age."
      }
    },
    {
      "@type": "Question",
      "name": "Is drooling at 3-4 months a sign of teething?",
      "acceptedAnswer": {
        "@type": "Answer",
